# ===========================
# App - 基本信息
# ===========================
VERSION="0.1.0"
APP_TITLE="FastSoyAdmin"
APP_DESCRIPTION="Description"
# 调试模式, 生产环境设为 false
APP_DEBUG=false

# ===========================
# Security - 密钥与JWT
# ===========================
# 用于JWT签名的密钥, 生产环境务必更换! 可用 openssl rand -hex 32 生成
SECRET_KEY="your-secret-key-here"
# JWT算法
JWT_ALGORITHM="HS256"
# Access Token 过期时间(分钟), 默认12小时
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720
# Refresh Token 过期时间(分钟), 默认7天
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ===========================
# CORS - 跨域配置
# ===========================
# 允许的来源, 生产环境建议指定具体域名
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ===========================
# Database - 数据库连接 URL
# ===========================
# Tortoise ORM 原生支持 sqlite/postgres/mysql/mssql 四种引擎, 只需改 DB_URL
# 即可切换; 业务模型会被 app/core/autodiscover 自动发现, 无需手工列模型路径。
# TORTOISE_ORM 配置字典会在启动时基于 DB_URL + autodiscover 自动构建, 请勿在此手写。
#
# --- SQLite (默认, 开发环境) ---
# 相对路径用两个斜杠 (文件在项目根目录):
DB_URL="sqlite://app_system.sqlite3?busy_timeout=5000"
# 绝对路径用三个斜杠:
# DB_URL="sqlite:///var/data/app_system.sqlite3?busy_timeout=5000&journal_mode=WAL"
#
# --- PostgreSQL ---
# 默认驱动 asyncpg:
# DB_URL="postgres://postgres:password@localhost:5432/fastsoyadmin"
# 显式指定驱动 (二选一):
# DB_URL="asyncpg://postgres:password@localhost:5432/fastsoyadmin"
# DB_URL="psycopg://postgres:password@localhost:5432/fastsoyadmin"
#
# --- MySQL / MariaDB ---
# DB_URL="mysql://root:password@localhost:3306/fastsoyadmin"
#
# --- Microsoft SQL Server ---
# DB_URL="mssql://sa:Password123@localhost:1433/fastsoyadmin?driver=ODBC%20Driver%2018%20for%20SQL%20Server&encrypt=no&trust_server_certificate=yes"

# ===========================
# Redis
# ===========================
# 格式: redis://:password@host:port/db
REDIS_URL="redis://localhost:6379/0"

# ===========================
# Datetime - 日期时间格式
# ===========================
DATETIME_FORMAT="%Y-%m-%d %H:%M:%S"

# ===========================
# Logs - 日志
# ===========================
# 普通日志(INFO/DEBUG/WARNING)保留时间, 支持: seconds/minutes/hours/days/weeks/months/years (如 "30 days", "1 months", "2 weeks")
LOG_INFO_RETENTION="30 days"

# ===========================
# Radar - 请求追踪
# ===========================
# 是否启用 Radar 请求追踪
RADAR_ENABLED=true
# Radar 数据库路径 (默认项目根目录下 radar.sqlite3)
# RADAR_DB_PATH="radar.sqlite3"
# 数据保留时间(小时)
RADAR_RETENTION_HOURS=24
# 记录的最大请求/响应体大小(字节)
RADAR_MAX_BODY_SIZE=65536
# 慢查询阈值(毫秒)
RADAR_SLOW_QUERY_THRESHOLD_MS=100.0
# 是否捕获响应体
RADAR_CAPTURE_RESPONSE_BODY=true
# 忽略追踪的路径(前缀匹配), JSON数组格式
# RADAR_EXCLUDE_PATHS='["/__radar", "/health", "/static", "/docs", "/openapi.json", "/redoc", "/doc", "/api/v1/monitor/", "/api/v1/route/constant-routes", "/api/v1/route/user-routes", "/api/v1/auth/user-info"]'
# 必须追踪的路径(前缀匹配), 优先级高于 EXCLUDE_PATHS
# RADAR_INCLUDE_PATHS='["/api/v1/auth/login", "/api/v1/auth/code-login", "/api/v1/auth/register", "/__radar/api/_boom"]'

# ===========================
# Proxy Headers - 反向代理
# ===========================
# 部署在 Nginx / CDN / 负载均衡之后时启用, granian 会从 X-Forwarded-For / X-Forwarded-Proto
# 还原真实客户端 IP 与协议。本地开发或直接暴露时保持 false, 避免 header 被伪造。
PROXY_HEADERS_ENABLED=false
# 受信任的上游白名单, 只有来自这些地址的请求才会被还原头部。
# 支持: 具体 IP (["127.0.0.1", "10.0.0.5"]) / CIDR (["10.0.0.0/8"]) / 通配 (["*"] — 仅在确认无法被公网直连时使用)
TRUSTED_HOSTS=["127.0.0.1"]

# ===========================
# FastAPI Guard - 安全防护
# ===========================
# 是否启用 Guard
GUARD_ENABLED=true
# 速率限制: 每个窗口期内最大请求数
GUARD_RATE_LIMIT=100
# 速率限制窗口期(秒)
GUARD_RATE_LIMIT_WINDOW=60
# 自动封禁触发阈值(次)
GUARD_AUTO_BAN_THRESHOLD=10
# 自动封禁持续时间(秒), 默认6小时
GUARD_AUTO_BAN_DURATION=21600
